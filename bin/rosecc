#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

LOCAL_BUN="$ROOT_DIR/.runtime/bun/windows-x64-1.3.11/bin/bun.exe"
BUN_BIN="${ROSECC_BUN_PATH:-}"
if [[ -z "$BUN_BIN" && -x "$LOCAL_BUN" ]]; then
  BUN_BIN="$LOCAL_BUN"
fi
if [[ -z "$BUN_BIN" ]]; then
  BUN_BIN="$(command -v bun || command -v bun.exe || true)"
fi
if [[ -z "$BUN_BIN" ]]; then
  echo "Error: bun is not installed or not available in PATH." >&2
  exit 1
fi

ARGS=()

if [[ "${ROSECC_LOAD_DOTENV:-0}" == "1" ]]; then
  ARGS+=(--env-file=.env)
fi

exec "$BUN_BIN" "${ARGS[@]}" ./src/entrypoints/rosecc.ts "$@"
