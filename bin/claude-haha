#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

BUN_BIN="$(command -v bun || command -v bun.exe || true)"
if [[ -z "$BUN_BIN" ]]; then
  echo "Error: bun is not installed or not available in PATH." >&2
  exit 1
fi

# Force recovery CLI (simple readline REPL, no Ink TUI)
if [[ "${CLAUDE_CODE_FORCE_RECOVERY_CLI:-0}" == "1" ]]; then
  exec "$BUN_BIN" --env-file=.env ./src/localRecoveryCli.ts "$@"
fi

# Default: full CLI with Ink TUI
exec "$BUN_BIN" --env-file=.env ./src/entrypoints/cli.tsx "$@"
